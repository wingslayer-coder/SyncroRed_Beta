# VITE_API_URL fijo causaba que el telefono llamara a su propio localhost.
# Comentado: el frontend usa http://<host-del-navegador>:8000/api (ver src/api/client.ts),
# asi funciona tanto en el PC (localhost) como desde el celular (IP del PC en la red).
# Para produccion, define aqui la URL real del backend.
# VITE_API_URL=http://localhost:8000/api
